{
  "cleanUrls": true,
  "headers": [
    {
      "source": "/assets/dict/(.*).db",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/octet-stream"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/catalogo", "destination": "/index.html" },
    { "source": "/login", "destination": "/index.html" },
    { "source": "/perfil", "destination": "/index.html" },
    { "source": "/admin", "destination": "/index.html" },
    { "source": "/play/(.*)", "destination": "/index.html" }
  ]
}
