{
  "outputDirectory": "dist/listening-japones/browser",
  "functions": {
    "api/translate.ts": {
      "runtime": "nodejs22.x"
    }
  },
  "headers": [
    {
      "source": "/assets/dict/(.*).db",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/octet-stream"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}