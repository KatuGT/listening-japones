{
  "cleanUrls": true,
  "headers": [
    {
      "source": "/assets/dict/(.*).db",
      "headers": [
        {
          "key": "Content-Encoding",
          "value": "identity"
        },
        {
          "key": "Content-Type",
          "value": "application/octet-stream"
        }
      ]
    }
  ]
}
